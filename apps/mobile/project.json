{
  "name": "@yasc/mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mobile",
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": { "command": "expo start", "cwd": "apps/mobile" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @yasc/mobile typecheck" }
    }
  }
}
