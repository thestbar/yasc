{
  "expo": {
    "name": "YASC",
    "slug": "yasc",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yasc.app"
    },
    "android": {
      "package": "com.yasc.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "yasc",
    "experiments": {
      "typedRoutes": true
    }
  }
}
