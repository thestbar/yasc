{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api",
  "tags": ["scope:api", "platform:server"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o ../../dist/api ./cmd/api",
        "cwd": "apps/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./...",
        "cwd": "apps/api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run ./... || true",
        "cwd": "apps/api"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run ./cmd/seed",
        "cwd": "apps/api"
      }
    }
  }
}
